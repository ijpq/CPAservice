# /etc/mem-alert.env  -- config for mem-alert.sh (chmod 600, owned by root)

# --- thresholds ---
MEM_AVAIL_WARN_PCT=15      # alert when available RAM drops below this %
SWAP_USED_WARN_PCT=70      # alert when swap usage exceeds this %
COOLDOWN_SEC=900           # min seconds between repeat alerts (15 min)

# --- Telegram (leave blank to disable) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Gmail via app password (leave blank to disable) ---
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_TO=